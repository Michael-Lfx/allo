# Copy to `.env.modelscope` (gitignored) before `bun run upload:modelscope`.
#
# Used by scripts/upload-modelscope-release.py when MODELSCOPE_TOKEN is not already
# set in the environment. Generate a token at:
#   https://www.modelscope.cn/my/myaccesstoken
#
# Keep it short-lived and revoke when no longer needed.
MODELSCOPE_TOKEN=ms-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
