# Flowy environment variables
#
# Copy this file to .env and fill in real values.
# docker compose automatically reads a .env file in the project root.
#
# Full reference: docs/reference/configuration.md

# ── Web host (nomifun-web) ──────────────────────────────────────────

# IP address to bind on. Use 0.0.0.0 for LAN/VPN access.
# Default: 127.0.0.1
NOMIFUN_WEB_HOST=127.0.0.1

# TCP port for API, WebSocket (/ws), and SPA.
# Default: 8787
NOMIFUN_WEB_PORT=8787

# Directory containing the built SPA (ui/dist).
# Set explicitly when deploying outside the repo.
# Default: ../../ui/dist (relative to apps/web)
# NOMIFUN_WEB_DIST=/path/to/ui/dist

# ── First-run admin (docker-compose / headless) ────────────────────

# Pre-seed the first admin username. Ignored once an admin exists.
# Default: admin
NOMIFUN_ADMIN_USERNAME=admin

# Pre-seed the first admin password. Ignored once an admin exists.
# Do NOT set to an empty string — the container will fail to boot.
# NOMIFUN_ADMIN_PASSWORD=change-me-to-something-strong

# ── Authentication ──────────────────────────────────────────────────

# DANGER: disable authentication entirely (desktop-style local mode).
# Only use on loopback or a fully trusted private network.
# Default: false
# NOMIFUN_WEB_INSECURE_NO_AUTH=false

# Secret used to sign session JWTs. If unset, a random secret is
# generated and persisted to the database on first boot.
# JWT_SECRET=generate-a-long-random-string-here

# Set to true when behind a TLS reverse proxy (Caddy, nginx).
# Makes session and CSRF cookies use Secure + SameSite=Strict.
# Default: false
# NOMIFUN_HTTPS=true

# ── Data and work directories ───────────────────────────────────────

# Backend data directory (SQLite, agent state, logs, Bun cache).
# Desktop app appends /Nomi; web and nomicore use it literally.
# Default: per-user app-data dir (see docs/reference/configuration.md)
# NOMIFUN_DATA_DIR=/var/lib/nomifun
# FLOWY_DATA_DIR=/var/lib/nomifun

# Working directory for conversation workspaces.
# Falls back to the data dir if unset.
# NOMIFUN_WORK_DIR=/var/lib/nomifun/work

# ── Logging ─────────────────────────────────────────────────────────

# tracing EnvFilter directive. Supports per-target overrides.
# Examples: info, debug, info,nomifun_mcp=trace
# Default: info
# NOMIFUN_LOG_LEVEL=info

# ── Remote capability API ───────────────────────────────────────────

# Base URL of a running Flowy instance (used by `nomicore call`).
# NOMIFUN_URL=http://127.0.0.1:8787

# Companion access token for /v1 Remote capability routes.
# Mint one via the WebUI or:
#   curl -X POST http://127.0.0.1:8787/api/webui/companions/<id>/access-token
# NOMIFUN_COMPANION_TOKEN=

# ── Shell (Linux/macOS servers) ─────────────────────────────────────

# Shell used when the agent engine spawns child processes.
# On systemd servers the system account often has no $SHELL — set it.
# SHELL=/bin/bash

# ── Docker compose build args ───────────────────────────────────────

# Override base images (useful with a Docker Hub proxy).
# BUN_IMAGE=oven/bun:1
# RUST_IMAGE=rust:1-slim-bookworm
# RUNTIME_IMAGE=debian:bookworm-slim

# Mirror registries for faster builds in China.
# BUN_REGISTRY=https://registry.npmmirror.com
# APT_MIRROR=http://mirrors.aliyun.com
# CARGO_REGISTRY_MIRROR=https://rsproxy.cn/index/

# ── CI / build ──────────────────────────────────────────────────────

# Set to 0 to skip embedding the Bun runtime at build time.
# Default: 1 (embed bun)
# NOMIFUN_EMBED_BUN=0
